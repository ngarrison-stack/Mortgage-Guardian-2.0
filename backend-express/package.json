{
  "name": "mortgage-guardian-backend",
  "version": "2.0.0",
  "description": "Vercel-optimized backend for Mortgage Guardian - No AWS required",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "vercel-build": "echo 'No build step needed'",
    "lint": "eslint services/ routes/ middleware/ schemas/ utils/ server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "loadtest": "node loadtest/runner.js",
    "loadtest:health": "node loadtest/runner.js --suite health",
    "loadtest:api": "node loadtest/runner.js --suite api",
    "loadtest:stress": "node loadtest/runner.js --suite stress",
    "loadtest:memory": "node loadtest/runner.js --suite memory"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@sentry/node": "^10.47.0",
    "@supabase/supabase-js": "^2.80.0",
    "argon2": "^0.44.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.2",
    "file-type": "^21.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "joi": "^18.0.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^4.0.1",
    "morgan": "^1.10.0",
    "pdf-parse": "^2.4.5",
    "plaid": "^41.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "autocannon": "^8.0.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "mortgage",
    "guardian",
    "claude",
    "ai",
    "plaid",
    "supabase",
    "vercel",
    "serverless"
  ],
  "author": "Mortgage Guardian Team",
  "license": "MIT"
}
