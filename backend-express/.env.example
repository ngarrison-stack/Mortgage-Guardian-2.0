# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ============================================
# ANTHROPIC CLAUDE AI
# ============================================
# Get your API key from: https://console.anthropic.com/
# Required for AI document analysis features
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ============================================
# PLAID CONFIGURATION
# ============================================
# Plaid API Credentials — get from: https://dashboard.plaid.com/team/keys
# Required for banking integration features
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret

# Environment: sandbox, development, or production
# - sandbox: For testing with fake data
# - development: For testing with real bank accounts (free for up to 100 Items)
# - production: For live production use (requires Plaid Production approval)
PLAID_ENV=sandbox

# Webhook Configuration (optional in dev, required in production)
# Must be publicly accessible HTTPS endpoint
# Example: https://your-domain.com/v1/plaid/webhook
PLAID_WEBHOOK_URL=

# Webhook Verification Key (required in production for webhook security)
# Get from Plaid Dashboard after setting up webhooks
PLAID_WEBHOOK_VERIFICATION_KEY=

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ============================================
# CLERK AUTHENTICATION (iOS/Mobile)
# ============================================
# Clerk issuer URL for JWT verification via JWKS
# Get from: https://dashboard.clerk.com → API Keys → Issuer URL
# Used to verify iOS/mobile tokens via RS256 JWKS endpoint
CLERK_ISSUER_URL=https://fond-mako-71.clerk.accounts.dev

# ============================================
# DOCUMENT SECURITY
# ============================================
# 256-bit AES encryption key for document storage (64 hex characters)
# Generate with: openssl rand -hex 32
DOCUMENT_ENCRYPTION_KEY=

# ============================================
# RATE LIMITING
# ============================================
# Rate limit window in milliseconds (default: 15 minutes = 900000ms)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window per IP (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS CONFIGURATION
# ============================================
# Allowed origins for CORS (comma-separated or * for all)
# Production: Must specify explicit origins (not *)
# Development: Use * to allow all origins
# Example: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=*

# ============================================
# INFRASTRUCTURE (optional)
# ============================================
# Redis — used for caching and rate limiting
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ============================================
# ERROR TRACKING (production-only)
# ============================================
# Sentry DSN for error tracking and performance monitoring
# Get from: https://sentry.io → Project Settings → Client Keys
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ============================================
# ADVANCED / CLOUD (optional)
# ============================================
# JWT_SECRET=
# AWS_REGION=us-east-1
# USE_CLOUD_HSM=false
# VAULT_TOKEN=
# KMS_KEY_ID=
# KMS_SIGNING_KEY_ID=
# ELASTICSEARCH_URL=
# ELASTICSEARCH_USER=
# ELASTICSEARCH_PASSWORD=
