# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# ANTHROPIC CLAUDE AI API
# ============================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ============================================
# PLAID CONFIGURATION
# ============================================
# Plaid API Credentials
# Get from: https://dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret

# Environment: sandbox, development, or production
# - sandbox: For testing with fake data
# - development: For testing with real bank accounts (free for up to 100 Items)
# - production: For live production use (requires Plaid Production approval)
PLAID_ENV=sandbox

# Webhook Configuration (Optional but recommended for production)
# This is the URL where Plaid will send webhook notifications
# Must be publicly accessible HTTPS endpoint
# Example: https://your-domain.com/v1/plaid/webhook
PLAID_WEBHOOK_URL=

# Webhook Verification Key (Required for webhook security)
# Get from Plaid Dashboard after setting up webhooks
# Used to verify webhook signatures using HMAC-SHA256
PLAID_WEBHOOK_VERIFICATION_KEY=

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ============================================
# SECURITY & RATE LIMITING
# ============================================
# Rate limit window in milliseconds (default: 15 minutes = 900000ms)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window per IP (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS CONFIGURATION
# ============================================
# Allowed origins for CORS (comma-separated or * for all)
# Production: Set to your iOS app's domain or specific origins
# Development: Use * to allow all origins
# Example: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=*
