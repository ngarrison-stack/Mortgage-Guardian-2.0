# Fastlane Environment Variables Example
# Copy this to .env and fill in your actual values

# Apple Developer Account
DEVELOPER_APP_ID="your-apple-id@example.com"
DEVELOPER_TEAM_ID="AQ4G5FP8KF"

# App Store Connect API Key (from https://appstoreconnect.apple.com/access/integrations/api)
APPLE_KEY_ID="YOUR_KEY_ID"
APPLE_ISSUER_ID="YOUR_ISSUER_ID"
APPLE_KEY_CONTENT="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----"

# Code Signing (match) - Create a private repo for storing certificates
MATCH_GIT_URL="git@github.com:yourusername/certificates.git"
PROVISIONING_PROFILE_SPECIFIER="match AppStore com.nickgarrison.mortgageguardian"

# Optional: Slack notifications
# SLACK_URL="https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK"