# Credential Management Best Practices
# =====================================

# NEVER commit actual values - use placeholders
# Store real values in:
# 1. Local: .env.local (gitignored)
# 2. CI/CD: GitHub Secrets
# 3. Production: AWS Secrets Manager / Parameter Store

# Required for iOS App
IOS_BUNDLE_ID=your-bundle-id
APPLE_TEAM_ID=your-team-id
APPLE_KEY_ID=your-key-id

# Required for Backend
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=vault:aws-secretsmanager:plaid/credentials:secret
PLAID_ENV=sandbox

# Required for AI Services
ANTHROPIC_API_KEY=vault:aws-secretsmanager:anthropic/api:key
OPENAI_API_KEY=vault:aws-secretsmanager:openai/api:key

# AWS Configuration (use IAM roles in production)
AWS_REGION=us-east-1
AWS_COGNITO_POOL_ID=your-pool-id

# Database (use AWS RDS IAM auth in production)
DATABASE_URL=vault:aws-secretsmanager:rds/connection:url

# Feature Flags
ENABLE_PLAID=true
ENABLE_AI_ANALYSIS=true
ENABLE_DOCUMENT_UPLOAD=true